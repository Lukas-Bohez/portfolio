{
  "name": "lbohez-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "update:portfolio": "./scripts/update-portfolio.sh",
    "export": "next export",
    "export:dist": "next build && node -e \"const fs=require('fs'),path=require('path'); const src='out', dst='dist'; function cp(s,d){ if(!fs.existsSync(d)) fs.mkdirSync(d,{recursive:true}); for(const e of fs.readdirSync(s,{withFileTypes:true})){ const ps=path.join(s,e.name), pd=path.join(d,e.name); if(e.isDirectory()) cp(ps,pd); else fs.copyFileSync(ps,pd); }} cp(src,dst);\"",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "test": "npm run lint && npm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "framer-motion": "^11.1.5",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@rtsao/scc": "^1.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
